# frozen_string_literal: true

# Development bundle for the shirobai-performance gem (specs live under
# gems/shirobai-performance/spec and run from this directory).
# Kept separate from the repo-root Gemfile on purpose: having
# rubocop-performance in the root bundle would make `rubocop/rspec/support`
# auto-integrate the plugin into the default configuration for the CORE spec
# suite too (CopHelper's before(:all) scans Gem.loaded_specs).
source "https://rubygems.org"

gemspec

gem "shirobai", path: "../.."

gem "rake", "~> 13.0"
gem "rspec", "~> 3.0"
